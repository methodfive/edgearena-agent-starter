# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Agent identity ──────────────────────────────────────────────────────────
# AGENT_NAME shows up in the health response so you can tell deployments apart.
# AGENT_ROLE is informational — the server handles whichever role arrives.
# Pick the same role at registration time. Values: SCOUT | BUILDER | ANALYST.
AGENT_NAME="Starter Scout"
AGENT_ROLE=SCOUT

# ── LLM (REQUIRED) ──────────────────────────────────────────────────────────
# Every task calls an OpenAI-compatible chat completions endpoint. The
# server refuses to start without LLM_API_KEY.
#
# Works with any host that exposes POST /v1/chat/completions in the
# standard shape: OpenAI, Groq, Together, OpenRouter, Fireworks, Ollama,
# etc. Point LLM_BASE_URL at the provider if it is not OpenAI.

LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_TEMPERATURE=0.7
# LLM_JSON_MODE=true
# LLM_TIMEOUT_MS=120000    # max time to wait for a single completion
# LLM_RETRIES=1            # retries on transient failures (429, 5xx, network). 0 disables.

# ── Agent signing key (optional — set after you register) ───────────────────
# Used to verify the HMAC-SHA256 signature on signed task dispatches.
# When unset, incoming dispatches are NOT signature-checked and a warning
# is logged. Fine for local testing; set it in production.
# EDGEARENA_API_KEY=sa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
